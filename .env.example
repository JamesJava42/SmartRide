POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rideconnect
POSTGRES_USER=rideconnect
POSTGRES_PASSWORD=changeme

REDIS_URL=redis://redis:6379/0

AUTH_SERVICE_URL=http://auth_service:8001
MARKETPLACE_SERVICE_URL=http://marketplace_service:8002
OPERATIONS_SERVICE_URL=http://operations_service:8003
NOTIFICATION_SERVICE_URL=http://notification_service:8004

JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

AUTH_DATABASE_URL=postgresql+asyncpg://rideconnect:changeme@postgres:5432/rideconnect
MARKETPLACE_DATABASE_URL=postgresql+asyncpg://rideconnect:changeme@postgres:5432/rideconnect
OPERATIONS_DATABASE_URL=postgresql+asyncpg://rideconnect:changeme@postgres:5432/rideconnect
NOTIFICATION_DATABASE_URL=postgresql+asyncpg://rideconnect:changeme@postgres:5432/rideconnect

# Google OAuth — get from https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MAX_DISPATCH_RETRIES=5
INTERNAL_SERVICE_TOKEN=rideconnect-internal-dev-token
